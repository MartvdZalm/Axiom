# Axiom — Doxygen configuration

PROJECT_NAME           = Axiom
PROJECT_BRIEF          = "State-machine DSL compiler (C++23)"
PROJECT_NUMBER         = 0.1.0

OUTPUT_DIRECTORY       = ../build/docs
CREATE_SUBDIRS         = YES
OUTPUT_LANGUAGE        = English

# Input
INPUT                  = \
    ../docs/mainpage.dox \
    ../axiom-core/include \
    ../axiom-ast/include \
    ../axiom-lexer/include \
    ../axiom-parser/include \
    ../axiom-semantic/include \
    ../axiom-codegen/include
INPUT_ENCODING         = UTF-8
FILE_PATTERNS          = *.hpp *.dox
RECURSIVE              = YES
EXCLUDE_PATTERNS       = */build/*

# Main page
USE_MDFILE_AS_MAINPAGE =

# Extraction
EXTRACT_ALL            = NO
EXTRACT_PRIVATE        = NO
EXTRACT_STATIC         = NO
EXTRACT_LOCAL_CLASSES  = YES
HIDE_UNDOC_MEMBERS     = YES
HIDE_UNDOC_CLASSES     = YES
HIDE_FRIEND_COMPOUNDS  = YES
HIDE_IN_BODY_DOCS      = YES
INTERNAL_DOCS          = NO
BRIEF_MEMBER_DESC      = YES
REPEAT_BRIEF           = YES
ALWAYS_DETAILED_SEC    = NO
JAVADOC_AUTOBRIEF      = YES
QT_AUTOBRIEF           = NO
MULTILINE_CPP_IS_BRIEF = YES

# Namespaces and grouping
SHOW_NAMESPACES        = YES
SHOW_INCLUDE_FILES     = YES
INLINE_SIMPLE_STRUCTS  = YES
TYPEDEF_HIDES_STRUCT   = NO

# Source browsing
SOURCE_BROWSER         = YES
INLINE_SOURCES         = NO
STRIP_CODE_COMMENTS    = YES
REFERENCED_BY_RELATION = YES
REFERENCES_RELATION    = YES

# HTML output
GENERATE_HTML          = YES
HTML_OUTPUT            = html
HTML_DYNAMIC_MENUS     = YES
SEARCHENGINE           = YES
GENERATE_TREEVIEW      = YES
DISABLE_INDEX          = NO
FULL_SIDEBAR           = NO

# Other backends
GENERATE_LATEX         = NO
GENERATE_XML           = NO

# Diagrams (optional Graphviz)
HAVE_DOT               = NO

# Warnings
WARN_IF_UNDOCUMENTED   = YES
WARN_IF_DOC_ERROR      = YES
WARN_NO_PARAMDOC       = YES
WARN_AS_ERROR          = NO

# Preprocessor (match project)
MACRO_EXPANSION        = YES
EXPAND_ONLY_PREDEF     = NO
PREDEFINED             = \
    [[nodiscard]]= \
    __attribute__(x)=
